    // Codeium/Windsurf keybindings
    { "key": "ctrl+alt+a",            "command": "codeium.openChatView"},
    { "key": "ctrl+enter",             "command": "refactorPreview.apply",
                                        "when": "refactorPreview.enabled && refactorPreview.hasCheckedChanges && focusedView == 'refactorPreview'" },
    { "key": "cmd+enter",               "command": "refactorPreview.apply",
                                        "when": "refactorPreview.enabled && refactorPreview.hasCheckedChanges && focusedView == 'refactorPreview'" },
    { "key": "ctrl+enter",             "command": "notebook.cell.chat.acceptChanges",
                                        "when": "inlineChatFocused && notebookCellChatFocused && !notebookCellEditorFocused" },
    { "key": "ctrl+enter",             "command": "notebook.cell.chat.acceptChanges",
                                        "when": "notebookEditorFocused && !inputFocus && !notebookCellEditorFocused && notebookChatOuterFocusPosition == 'below'" },
    { "key": "ctrl+enter",             "command": "chatEditing.acceptAllFiles",
                                        "when": "hasUndecidedChatEditingResource && inChatInput && !chatSessionRequestInProgress" },
    { "key": "cmd+enter",               "command": "chatEditing.acceptAllFiles",
                                        "when": "hasUndecidedChatEditingResource && inChatInput && !chatSessionRequestInProgress" },
    { "key": "ctrl+enter",             "command": "chatEditor.action.accept",
                                        "when": "chatEdits.hasEditorModifications && editorFocus && !chatEdits.isRequestInProgress" },
    { "key": "ctrl+enter",             "command": "inlineChat.acceptChanges",
                                        "when": "inlineChatHasProvider && inlineChatVisible" },
    { "key": "ctrl+enter",             "command": "windsurf.terminalCommand.run",
                                        "when": "terminalFocus && windsurf.canTriggerTerminalCommandAction" },
    { "key": "ctrl+enter",             "command": "windsurf.command.accept",
                                        "when": "editorTextFocus && windsurf.canAcceptOrRejectCommand && !editorHasSelection" },
    { "key": "ctrl+enter",             "command": "windsurf.prioritized.cascadeAcceptAllInFile",
                                        "when": "editorTextFocus && windsurf.canAcceptOrRejectAllCascadeEditsInFile" },
    { "key": "cmd+enter",               "command": "windsurf.prioritized.cascadeAcceptAllInFile",
                                        "when": "editorTextFocus && windsurf.canAcceptOrRejectAllCascadeEditsInFile" },

    // Neovim scrolling keybindings
    // Custom solution found from https://github.com/vscode-neovim/vscode-neovim/issues/983#issuecomment-1960709776
    // Disable default VSCode keybindings for Ctrl+u and Ctrl+d in normal mode
    {
        "key": "ctrl+u",
        "command": "-vscode-neovim.ctrl-u",
        "when": "editorTextFocus && neovim.ctrlKeysNormal.u && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
    },
    {
        "key": "ctrl+d",
        "command": "-vscode-neovim.ctrl-d",
        "when": "editorTextFocus && neovim.ctrlKeysNormal.d && neovim.init && neovim.mode != 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
    },
    // Enable Neovim custom keybindings for scrolling
    {
        "key": "ctrl+u",
        "command": "runCommands",
        "args": {
            "commands": [
                {
                    "command": "editorScroll",
                    "args": {
                        "to": "up",
                        "by": "halfPage"
                    }
                },
                {
                    "command": "cursorMove",
                    "args": { "to": "viewPortCenter" }
                }
            ]
        },
        "when": "neovim.init && neovim.mode != 'insert'" // Allows for markdown underline shortcut
      },
      {
        "key": "ctrl+d",
        "command": "runCommands",
        "args": {
            "commands": [
                {
                    "command": "editorScroll",
                    "args": {
                        "to": "down",
                        "by": "halfPage"
                    }
                },
                {
                    "command": "cursorMove",
                    "args": { "to": "viewPortCenter" }
                }
            ]
        }
    },
    // Full page scrolls
    {
        "key": "ctrl+b",
        "command": "runCommands",
        "args": {
            "commands": [
                {
                  "command": "editorScroll",
                  "args": {
                    "to": "up",
                    "by": "page"
                  }
                },
                {
                  "command": "cursorMove",
                  "args": {
                    "to": "viewPortCenter"
                  }
                }
            ]
        }
    },
    {
        "key": "ctrl+f",
        "command": "runCommands",
        "args": {
            "commands": [
                {
                  "command": "editorScroll",
                  "args": {
                    "to": "down",
                    "by": "page"
                  }
                },
                {
                  "command": "cursorMove",
                  "args": {
                    "to": "viewPortCenter"
                  }
                }
            ]
        }
    },

    // Neovim Python Notebook keybindings
    // Turn off default notebook navigation that interferes with file lookup
    {
      "key": "ctrl+n",
      "command": "-list.focusDown",
      "when": "listFocus && !inputFocus"
    },
    {
      "key": "ctrl+p",
      "command": "-list.focusUp",
      "when": "listFocus && !inputFocus"
    },
    // Enable h & l to fold and unfold cells like arrow keys
    {
        "key": "h",
        "command": "notebook.fold",
        "when": "notebookEditorFocused && !inputFocus && activeEditor == 'workbench.editor.notebook'"
    },
    {
        "key": "l",
        "command": "notebook.unfold",
        "when": "notebookEditorFocused && !inputFocus && activeEditor == 'workbench.editor.notebook'"
    },
    // Use o & O to insert new cells above and below
    { "key": "shift+o",                     "command": "notebook.cell.insertCodeCellAboveAndFocusContainer",
                                        "when": "notebookEditorFocused && !inputFocus && !notebookOutputInputFocused" },
    { "key": "o",                     "command": "notebook.cell.insertCodeCellBelowAndFocusContainer",
                                        "when": "notebookEditorFocused && !inputFocus && !notebookOutputInputFocused" },
    
    // Misc keybindings
    // Find keybindings
    { "key": "ctrl+alt+f",                 "command": "actions.find",
                                        "when": "editorFocus || editorIsOpen" },
    { "key": "ctrl+alt+f",                 "command": "editor.action.extensioneditor.showfind",
                                        "when": "!editorFocus && activeEditor == 'workbench.editor.extension'" },
    { "key": "ctrl+alt+f",                 "command": "editor.action.webvieweditor.showFind",
                                        "when": "webviewFindWidgetEnabled && !editorFocus && activeEditor == 'WebviewEditor'" },
    { "key": "ctrl+alt+f",                 "command": "editor.action.webvieweditor.showFind",
                                        "when": "webviewFindWidgetEnabled && !editorFocus && activeEditor == 'WebviewEditor'" },
    { "key": "ctrl+alt+f",                 "command": "repl.action.filter",
                                        "when": "inDebugRepl && textInputFocus" },
    { "key": "ctrl+alt+f",                 "command": "settings.action.search",
                                        "when": "inSettingsEditor" },
    { "key": "ctrl+alt+f",                 "command": "commentsFocusFilter",
                                        "when": "focusedView == 'workbench.panel.comments'" },
    { "key": "ctrl+alt+f",                 "command": "keybindings.editor.searchKeybindings",
                                        "when": "inKeybindings" },
    { "key": "ctrl+alt+f",                 "command": "notebook.find",
                                        "when": "notebookEditorFocused && !editorFocus && activeEditor == 'workbench.editor.interactive' || notebookEditorFocused && !editorFocus && activeEditor == 'workbench.editor.notebook'" },
    { "key": "ctrl+alt+f",                 "command": "problems.action.focusFilter",
                                        "when": "focusedView == 'workbench.panel.markers.view'" },
    { "key": "ctrl+alt+f",                 "command": "workbench.action.terminal.focusFind",
                                        "when": "terminalFindFocused && terminalHasBeenCreated || terminalFindFocused && terminalProcessSupported || terminalFocusInAny && terminalHasBeenCreated || terminalFocusInAny && terminalProcessSupported" },
                                     
                                     
    // File opening
    {
        "key": "ctrl+k ctrl+o",
        "command": "-workbench.action.files.openFolder",
        "when": "openFolderWorkspaceSupport"
    },
    {
        "key": "ctrl+o",
        "command": "-workbench.action.files.openFileFolder",
        "when": "isMacNative && openFolderWorkspaceSupport"
    },
    {
        "key": "ctrl+o",
        "command": "workbench.action.files.openFolder"
    },
    {
        "key": "ctrl+o",
        "command": "workbench.action.files.openLocalFolder",
        "when": "remoteFileDialogVisible"
    },
    {
        "key": "ctrl+k ctrl+o",
        "command": "-workbench.action.files.openLocalFolder",
        "when": "remoteFileDialogVisible"
    },
    // Turns off overtype mode
    { 
        "key": "insert",
        "command": "-editor.action.toggleovertypeinsertmode"
    },
    // Toggle sidebar
    {
        "key": "shift+ctrl+b",
        "command": "workbench.action.toggleSidebarVisibility",
    },
    // Open dbt lineages
    {
        "key": "ctrl+cmd+l",
        "command": "workbench.view.extension.lineage_view",
        "when": "isMac"
    }
]