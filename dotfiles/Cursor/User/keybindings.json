[
    // Mac-style navigation keybindings -- only available in Neovim insert mode
    {
        "key": "alt+left",
        "command": "cursorWordAccessibilityLeft",
        "when": "accessibilityModeEnabled && isLinux && textInputFocus && focusedView == 'workbench.panel.output'"
    },
    {
        "key": "ctrl+left",
        "command": "-cursorWordAccessibilityLeft",
        "when": "accessibilityModeEnabled && isLinux && textInputFocus && focusedView == 'workbench.panel.output'"
    },
    {
        "key": "shift+alt+left",
        "command": "cursorWordAccessibilityLeftSelect",
        "when": "accessibilityModeEnabled && isLinux && textInputFocus && focusedView == 'workbench.panel.output'"
    },
    {
        "key": "ctrl+shift+left",
        "command": "-cursorWordAccessibilityLeftSelect",
        "when": "accessibilityModeEnabled && isLinux && textInputFocus && focusedView == 'workbench.panel.output'"
    },
    {
        "key": "alt+right",
        "command": "cursorWordAccessibilityRight",
        "when": "accessibilityModeEnabled && isLinux && textInputFocus && focusedView == 'workbench.panel.output'"
    },
    {
        "key": "ctrl+right",
        "command": "-cursorWordAccessibilityRight",
        "when": "accessibilityModeEnabled && isLinux && textInputFocus && focusedView == 'workbench.panel.output'"
    },
    {
        "key": "shift+alt+right",
        "command": "cursorWordAccessibilityRightSelect",
        "when": "accessibilityModeEnabled && isLinux && textInputFocus && focusedView == 'workbench.panel.output'"
    },
    {
        "key": "ctrl+shift+right",
        "command": "-cursorWordAccessibilityRightSelect",
        "when": "accessibilityModeEnabled && isLinux && textInputFocus && focusedView == 'workbench.panel.output'"
    },
    {
        "key": "alt+right",
        "command": "cursorWordEndRight",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "ctrl+right",
        "command": "-cursorWordEndRight",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "shift+alt+right",
        "command": "cursorWordEndRightSelect",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "ctrl+shift+right",
        "command": "-cursorWordEndRightSelect",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "alt+left",
        "command": "cursorWordLeft",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "ctrl+left",
        "command": "-cursorWordLeft",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "shift+alt+left",
        "command": "cursorWordLeftSelect",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "ctrl+shift+left",
        "command": "-cursorWordLeftSelect",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "ctrl+right",
        "command": "cursorEnd",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "end",
        "command": "-cursorEnd",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "ctrl+shift+right",
        "command": "cursorEndSelect",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "shift+end",
        "command": "-cursorEndSelect",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "ctrl+left",
        "command": "cursorHome",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "home",
        "command": "-cursorHome",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "ctrl+shift+left",
        "command": "cursorHomeSelect",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "shift+home",
        "command": "-cursorHomeSelect",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "ctrl+down",
        "command": "cursorBottom",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "ctrl+end",
        "command": "-cursorBottom",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "ctrl+up",
        "command": "cursorTop",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "ctrl+home",
        "command": "-cursorTop",
        "when": "textInputFocus && isLinux"
    },
    {
        "key": "ctrl+right",
        "command": "-editor.action.inlineSuggest.acceptNextWord",
        "when": "inlineSuggestionVisible && isLinux && !editorReadonly"
    },
    {
        "key": "alt+backspace",
        "command": "deleteWordLeft",
        "when": "textInputFocus && isLinux && !editorReadonly"
    },
    {
        "key": "ctrl+backspace",
        "command": "-deleteWordLeft",
        "when": "textInputFocus && isLinux && !editorReadonly"
    },
    {
        "key": "alt+delete",
        "command": "deleteWordRight",
        "when": "textInputFocus && isLinux && !editorReadonly"
    },
    {
        "key": "ctrl+delete",
        "command": "-deleteWordRight",
        "when": "textInputFocus && isLinux && !editorReadonly"
    },
    {
        "key": "ctrl+backspace",
        "command": "deleteAllLeft",
        "when": "isLinux"
    },
    {
        "key": "ctrl+delete",
        "command": "deleteAllRight",
        "when": "isLinux"
    },
    
    // Linux-style file lookup
    {   
        "key": "ctrl+p",
        "command": "workbench.action.quickOpenNavigateNextInFilePicker",
        "when": "inFilesPicker && inQuickOpen && isMac"
    },
    {
        "key": "ctrl+p",
        "command": "workbench.action.quickOpen",
        "when": "isMac"
    },
    
    // Tab switching
    { // Enable global editor switching everywhere else (explorer, terminal, etc.)
        "key": "ctrl+tab",
        "command": "workbench.action.quickOpenPreviousRecentlyUsedEditorInGroup",
        "when": "!inEditorsPicker && !inQuickOpen && !inlineSuggestionVisible"
    },
    // { // Maintains default tab switching behavior when inline suggestions are not visible
    //     "key": "ctrl+tab",
    //     "command": "workbench.action.quickOpenNavigateNextInEditorPicker",
    //     "when": "inEditorsPicker && inQuickOpen && !inlineSuggestionVisible"
    // },
    { // Disable editor switching while inline suggestions are visible in the editor
        "key": "ctrl+tab",
        "command": "-workbench.action.quickOpenPreviousRecentlyUsedEditorInGroup", // Opens Editor Picker
        // "when": "editorTextFocus && inlineSuggestionVisible"
        "when": "((cppSuggestion && !editorReadonly) || (inlineSuggestionVisible && !editorReadonly)) && (!neovim.init || neovim.mode == 'insert')"
    },
    { // Disable editor switching while inline suggestions are visible in the editor
        "key": "ctrl+tab",
        "command": "-workbench.action.quickOpenNavigateNextInEditorPicker", // Navigates Editor Picker
        // "when": "editorTextFocus && inlineSuggestionVisible"
        "when": "((cppSuggestion && !editorReadonly) || (inlineSuggestionVisible && !editorReadonly)) && (!neovim.init || neovim.mode == 'insert')"
    },
    { // Use ctrl+tab for partial suggestion acceptance when inline suggestions are visible
        "key": "ctrl+tab",
        "command": "editor.action.inlineSuggest.acceptNextWord",
        // "when": "editorTextFocus && inlineSuggestionVisible && !inEditorsPicker && !inQuickOpen && !editorReadonly"
        "when": "((cppSuggestion && !editorReadonly) || (inlineSuggestionVisible && !editorReadonly)) && (!neovim.init || neovim.mode == 'insert')"
    },

    // Markdown keybindings
    {
        "key": "ctrl+u",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == 'markdown' && (!neovim.init || neovim.mode == 'insert')",
        "args": {
            "snippet": "<u>$TM_SELECTED_TEXT</u>"
        }
    },
    
    // Find keybindings
    { "key": "ctrl+alt+f",                 "command": "actions.find",
                                        "when": "editorFocus || editorIsOpen" },
    { "key": "ctrl+alt+f",                 "command": "editor.action.extensioneditor.showfind",
                                        "when": "!editorFocus && activeEditor == 'workbench.editor.extension'" },
    { "key": "ctrl+alt+f",                 "command": "editor.action.webvieweditor.showFind",
                                        "when": "webviewFindWidgetEnabled && !editorFocus && activeEditor == 'WebviewEditor'" },
    { "key": "ctrl+alt+f",                 "command": "editor.action.webvieweditor.showFind",
                                        "when": "webviewFindWidgetEnabled && !editorFocus && activeEditor == 'WebviewEditor'" },
    { "key": "ctrl+alt+f",                 "command": "repl.action.filter",
                                        "when": "inDebugRepl && textInputFocus" },
    { "key": "ctrl+alt+f",                 "command": "settings.action.search",
                                        "when": "inSettingsEditor" },
    { "key": "ctrl+alt+f",                 "command": "commentsFocusFilter",
                                        "when": "focusedView == 'workbench.panel.comments'" },
    { "key": "ctrl+alt+f",                 "command": "keybindings.editor.searchKeybindings",
                                        "when": "inKeybindings" },
    { "key": "ctrl+alt+f",                 "command": "notebook.find",
                                        "when": "notebookEditorFocused && !editorFocus && activeEditor == 'workbench.editor.interactive' || notebookEditorFocused && !editorFocus && activeEditor == 'workbench.editor.notebook'" },
    { "key": "ctrl+alt+f",                 "command": "problems.action.focusFilter",
                                        "when": "focusedView == 'workbench.panel.markers.view'" },
    { "key": "ctrl+alt+f",                 "command": "workbench.action.terminal.focusFind",
                                        "when": "terminalFindFocused && terminalHasBeenCreated || terminalFindFocused && terminalProcessSupported || terminalFocusInAny && terminalHasBeenCreated || terminalFocusInAny && terminalProcessSupported" },
    

