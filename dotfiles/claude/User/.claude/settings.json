{
  "env": {
    "ANTHROPIC_MODEL": "haiku",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "EDITOR": "nvim"
  },
  "permissions": {
    "allow": [
      "Bash(/tmp/*)",
      "Bash(bash -n *)",
      "Bash(bazel query:*)",
      "Bash(bazel run:*)",
      "Bash(bazel test:*)",
      "Bash(cat *)",
      "Bash(claude --print:*)",
      "Bash(claude mcp:*)",
      "Bash(claude plugin:*)",
      "Bash(claude plugins:*)",
      "Bash(cp *)",
      "Bash(curl -s* *graphite.com/docs/*)",
      "Bash(curl -s* *localhost:*)",
      "Bash(do echo:*)",
      "Bash(do mkdir:*)",
      "Bash(done)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(find *)",
      "Bash(gh api:*)",
      "Bash(gh auth:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo:*)",
      "Bash(gh run:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git ls-tree:*)",
      "Bash(git push:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git worktree:*)",
      "Bash(grep *)",
      "Bash(grep:*)",
      "Bash(gt create:*)",
      "Bash(gt log:*)",
      "Bash(gt restack:*)",
      "Bash(jobs:*)",
      "Bash(jq:*)",
      "Bash(ls *)",
      "Bash(lsof -i TCP -sTCP:LISTEN)",
      "Bash(md5 *)",
      "Bash(mkdir *)",
      "Bash(open:*)",
      "Bash(python -c *)",
      "Bash(python -m py_compile *)",
      "Bash(python3 -c *)",
      "Bash(python3 -m json.tool *)",
      "Bash(sed *)",
      "Bash(source .venv/bin/activate)",
      "Bash(uv --version)",
      "Bash(uv run:*)",
      "Bash(wait:*)",
      "Bash(wc *)",
      "Bash(while read:*)",
      "Bash(xargs cat:*)",
      "Bash(xargs ls:*)",
      "Read(//Users/tyleranderton/.claude/**)",
      "Read(//Users/tyleranderton/Repositories/MacAutoSetup/dotfiles/claude/**)",
      "Read(//tmp/**)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:graphite.com)",
      "WebFetch(domain:graphite.dev)"
    ],
    "defaultMode": "default"
  },
  "model": "haiku",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '/caveman ultra'",
            "statusMessage": "Activating Caveman Token Optimization..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command')\nif echo \"$cmd\" | grep -qE '\\bsed\\b'; then\n  if echo \"$cmd\" | grep -qE '(\\s-([a-zA-Z]*i|i\\b)|--in-place|w\\s+\\S+)'; then\n    echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Write operations forbidden\"}}'\n    exit 0\n  fi\nfi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; echo \"$f\" | grep -q '\\.py$' && /opt/homebrew/bin/uv run ruff \"$f\" 2>/dev/null || true; }",
            "statusMessage": "Formatting with ruff..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"/Users/tyleranderton/.claude/plugins/marketplaces/caveman/hooks/caveman-statusline.sh\""
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": false,
    "atlassian@claude-plugins-official": false,
    "caveman@caveman": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "slack@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "taches-cc-resources@taches-cc-resources": false
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "taches-cc-resources": {
      "source": {
        "source": "github",
        "repo": "glittercowboy/taches-cc-resources"
      }
    }
  },
  "effortLevel": "low"
}
